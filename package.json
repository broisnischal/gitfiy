{
  "name": "gitfiy",
  "version": "0.2.0",
  "description": "Minimal MCP server to explore repositories, commits, diffs, and development patterns.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "gitfiy": "dist/index.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nees/gitfiy.git"
  },
  "homepage": "https://github.com/nees/gitfiy#readme",
  "bugs": {
    "url": "https://github.com/nees/gitfiy/issues"
  },
  "author": "nees",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    }
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "git",
    "github",
    "repo-analysis",
    "changesets"
  ],
  "scripts": {
    "build": "bunx obuild",
    "dev": "bun run src/index.ts",
    "start": "bun dist/index.mjs",
    "typecheck": "bunx tsc --noEmit",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.6.0",
    "obuild": "^0.4.33",
    "typescript": "^6.0.3"
  }
}